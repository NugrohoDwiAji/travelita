// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

enum BookingType {
  SHUTTLE
  TRIP
  PRIVATE_CAR
  SPEAR_CAR
  TICKET
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  PROCESSING
}

enum ShuttleType {
 ONE_WAY
 ROUND_TRIP
}

enum UserRole {
  USER
  ADMIN
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"

}

model User {
  id        String   @id @default(uuid())
  name      String
  username  String   
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile?
  booking   Booking?

  @@map("user")
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  coutry   String
  city     String
  profilePicture String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User    @relation(fields: [userId], references: [id])
@@map("profile")
}

model Booking {
  id        Int      @id @default(autoincrement())
  userId    String @unique
  details   Int
  type      BookingType
  status    BookingStatus
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User    @relation(fields: [userId], references: [id])

  @@map("booking")
}

model ShuttleBooking {
  id        Int      @id @default(autoincrement())
  shuttleType ShuttleType
  from String
  to String
  leavingTime DateTime
  returnTime DateTime?
  passengerCount Int
  price Float
  description String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shuttle_booking")
}
